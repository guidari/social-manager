# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# Project dashboard → "Connect" → ORMs tab → Prisma preset.
# DATABASE_URL: shared transaction-mode pooler (port 6543, IPv4-only) — runtime.
# DIRECT_URL: shared session-mode pooler (port 5432) — used by Prisma Migrate,
# which needs a connection that supports DDL.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Session / Auth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ─── Token Encryption (account OAuth tokens at rest) ─────────────────────────
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ─── Google OAuth (YouTube) ───────────────────────────────────────────────────
# https://console.cloud.google.com → OAuth 2.0 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated redirect URIs registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/accounts/youtube/callback

# ─── TikTok OAuth ─────────────────────────────────────────────────────────────
# https://developers.tiktok.com → Login Kit credentials
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/accounts/tiktok/callback

# ─── AWS S3 (media storage) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=postpilot-media-dev

# ─── BullMQ / Worker ──────────────────────────────────────────────────────────
# Uses REDIS_URL above; set to 'true' to run the worker in-process during dev
RUN_WORKER_IN_PROCESS=true
